# Arquivo de exemplo
# Copie este arquivo para ".env" e ajuste os valores para o seu ambiente local.

# Servidor
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
JWT_SECRET=troque_esta_chave_por_um_valor_forte

# Banco de dados (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=quiz_direito_local

# E-mail / Resend
# Opcional para desenvolvimento local.
# Preencha apenas se quiser testar a recuperacao de senha por e-mail.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_TEST_RECEIVER=
